# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=file:./dev.db

# OpenAI (optional — local heuristics used when not set)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Stripe (optional — billing disabled when not set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (optional — in-memory fallback when not set)
REDIS_URL=

# ── Cash SaaS Core V2 (monetization backend) ──
# Integration auto-enables when both env vars are set.
# Get CASH_SAAS_ADMIN_API_KEY by calling POST /auth/login on your cash-saas instance.
CASH_SAAS_CORE_URL=http://localhost:8000
CASH_SAAS_ADMIN_API_KEY=
